  },
  "scripts": {
    "build:semantic": "yarn --cwd node_modules/fomantic-ui gulp build",
    "bundle:install": "bundle install",
    "bundle:update": "bundle update",
    "kill:osx": "lsof -t -i tcp:4004 | xargs kill -9",
    "update": "rm -rf node_modules && rm -f yarn.lock && yarn bundle:update && yarn",
    "start": "rm -rf _site/ && bundle exec jekyll build && bundle exec jekyll serve --ssl-key ssl/server.key --ssl-cert ssl/server.crt --port 4004 --watch",
    "start:drafts": "rm -rf _site/ && bundle exec jekyll build && bundle exec jekyll serve --ssl-key ssl/server.key --ssl-cert ssl/server.crt --port 4004 --drafts --watch"
  },
